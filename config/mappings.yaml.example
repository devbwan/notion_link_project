version: 1

document:
  category: notion
  format: markdown

output:
  default_format: markdown
  allowed_formats: [markdown, json, csv]
  root: output
  path_template: "{category}/{page_id}.{extension}"
  empty_values: omit
  csv:
    columns: [type, title, content, tags, notion_page_id]
    multi_value_separator: "|"
    encoding: utf-8
    include_header: true
